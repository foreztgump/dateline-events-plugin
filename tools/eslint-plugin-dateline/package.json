{
  "name": "@dateline/eslint-plugin-dateline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.59.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.27.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
