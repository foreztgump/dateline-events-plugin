{
	"name": "dateline-platform-probe",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": "./dist/plugin.mjs"
	},
	"files": [
		"dist",
		"emdash-plugin.jsonc"
	],
	"scripts": {
		"build": "mkdir -p tmp && TMPDIR=./tmp emdash-plugin build",
		"dev": "emdash-plugin dev",
		"probe": "node scripts/run-probe.mjs",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --config ./vitest.config.ts"
	},
	"peerDependencies": {
		"emdash": "^0.18.0"
	},
	"devDependencies": {
		"@emdash-cms/plugin-cli": "0.5.1",
		"@types/better-sqlite3": "7.6.13",
		"better-sqlite3": "12.9.0",
		"emdash": "0.18.0",
		"esbuild": "0.27.7",
		"kysely": "0.29.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@emdash-cms/sandbox-workerd": "0.1.6",
		"astro": "6.2.1",
		"zod": "4.4.2"
	}
}
