{
  "name": "@dateline/reference-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "build": "astro build",
    "typecheck": "astro check && tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo .astro",
    "lint:fix": "eslint src --cache --fix"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.3.0",
    "@dateline/core": "workspace:*",
    "@dateline/importer": "workspace:*",
    "@dateline/recurring": "workspace:*",
    "@dateline/rsvp": "workspace:*",
    "@dateline/views": "workspace:*",
    "astro": "^6.1.10",
    "emdash": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "@astrojs/check": "^0.9.9"
  }
}
