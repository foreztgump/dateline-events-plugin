{
  "name": "@dateline/reference-site",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "build": "astro build",
    "typecheck": "astro check && tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "seed": "node scripts/seed.mjs",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo .astro data.db uploads",
    "lint:fix": "eslint src --cache --fix"
  },
  "emdash": {
    "seed": "seed/seed.json"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.3.0",
    "@astrojs/node": "10.0.6",
    "@dateline/blocks": "workspace:*",
    "@dateline/core": "workspace:*",
    "@dateline/importer": "workspace:*",
    "@dateline/recurring": "workspace:*",
    "@dateline/rsvp": "workspace:*",
    "@dateline/views": "workspace:*",
    "@emdash-cms/cloudflare": "0.18.0",
    "@emdash-cms/sandbox-workerd": "0.1.6",
    "astro": "^6.1.10",
    "better-sqlite3": "^12.9.0",
    "emdash": "^0.18",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "1.60.0",
    "@types/node": "^20.19.39",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
