---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Dateline v0.1 reference site" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
    <style is:global>
      :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, sans-serif; }
      body { margin: 0; background: #f8fafc; color: #0f172a; }
      a { color: inherit; }
      .site-shell { margin: 0 auto; max-width: 72rem; padding: 2rem; }
      .site-nav { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; }
      .site-nav a, .button-link { border-radius: 999px; background: #1d4ed8; color: white; padding: .65rem 1rem; text-decoration: none; }
      .hero, .panel { border: 1px solid #dbeafe; border-radius: 1.25rem; background: white; padding: 1.5rem; box-shadow: 0 12px 30px rgb(15 23 42 / 8%); }
      .grid-stack { display: grid; gap: 1.5rem; }
      .two-column { display: grid; grid-template-columns: minmax(0, 2fr) minmax(18rem, 1fr); gap: 1.5rem; }
      @media (max-width: 860px) { .two-column { grid-template-columns: 1fr; } }
      table { background: white; }
      th, td { border: 1px solid #cbd5e1; }
      .dt-event-card, .dt-rsvp-form, .dt-event-detail__meta, .dt-venue-map { background: white; }
    </style>
  </head>
  <body>
    <main class="site-shell">
      <nav class="site-nav" aria-label="Reference site">
        <a href="/">Calendar</a>
        <a href="/events">Events</a>
        <a href="/events.ics">iCal feed</a>
      </nav>
      <slot />
    </main>
  </body>
</html>
