---
import EventDetail from "@dateline/views/components/EventDetail.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadEventBySlug, loadOrganizersForEvent, loadVenueForEvent } from "../../lib/events.js";

const slug = Astro.params.slug ?? "";
const event = await loadEventBySlug(slug);
if (!event) return Astro.redirect("/events");
const [venue, organizers] = await Promise.all([loadVenueForEvent(event), loadOrganizersForEvent(event)]);
---
<BaseLayout title={`${event.title} | Dateline`}>
  <section class="grid-stack">
    <EventDetail event={event} venue={venue} organizers={organizers} rsvpAction="/api/rsvp" />
  </section>
</BaseLayout>
