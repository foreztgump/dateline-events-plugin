---
import BaseLayout from "../layouts/BaseLayout.astro";
const DEFAULT_EVENT_SLUG = "friday-meetup";
const eventTitle = Astro.url.searchParams.get("title") ?? Astro.url.searchParams.get("event") ?? "your event";
const eventSlug = Astro.url.searchParams.get("event") ?? DEFAULT_EVENT_SLUG;
const email = Astro.url.searchParams.get("email");
---
<BaseLayout title="RSVP confirmed">
  <section class="hero" role="status">
    <h1>You're confirmed for {eventTitle}</h1>
    <p>Your spot has been reserved in the Dateline reference flow{email ? ` for ${email}` : ""}.</p>
    <a class="button-link" href={`/events/${encodeURIComponent(eventSlug)}`}>Back to the RSVP event</a>
  </section>
</BaseLayout>
