{
  "name": "@dateline/rsvp",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "description": "Sandboxed EmDash plugin adding free RSVP to Dateline events: capacity enforcement, waitlists, confirmation email, and attendee status. No payment provider required.",
  "keywords": [
    "emdash",
    "emdash-plugin",
    "dateline",
    "rsvp",
    "events",
    "waitlist",
    "cloudflare-workers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foreztgump/dateline-events-plugin.git",
    "directory": "packages/rsvp"
  },
  "homepage": "https://github.com/foreztgump/dateline-events-plugin/tree/main/packages/rsvp#readme",
  "bugs": {
    "url": "https://github.com/foreztgump/dateline-events-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./sandbox": {
      "types": "./dist/plugin.d.mts",
      "import": "./dist/plugin.mjs",
      "default": "./dist/plugin.mjs"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "emdash-plugin.jsonc",
    "README.md"
  ],
  "scripts": {
    "build": "mkdir -p node_modules/.cache/emdash-build && TMPDIR=./node_modules/.cache/emdash-build emdash-plugin build && node ../../tools/bundle-sandbox-plugin.mjs && tsc -b",
    "dev": "emdash-plugin dev",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "peerDependencies": {
    "emdash": "^0.18.0"
  },
  "devDependencies": {
    "@emdash-cms/plugin-cli": "^0.5.1",
    "@types/node": "^20.19.39",
    "esbuild": "^0.27.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@dateline/blocks": "workspace:*",
    "zod": "4.4.2"
  }
}
