{
  "name": "@dateline/blocks",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "description": "Thin Block Kit wrapper for Dateline over @emdash-cms/blocks: re-exports typed builders, validateBlocks, and block/element types, plus the assertResponse plugin-route envelope guard. Safe to bundle into sandboxed plugins.",
  "keywords": [
    "dateline",
    "emdash",
    "block-kit",
    "blocks",
    "ui",
    "cloudflare-workers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foreztgump/dateline-events-plugin.git",
    "directory": "packages/blocks"
  },
  "homepage": "https://github.com/foreztgump/dateline-events-plugin/tree/main/packages/blocks#readme",
  "bugs": {
    "url": "https://github.com/foreztgump/dateline-events-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "peerDependencies": {
    "emdash": "^0.18"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@emdash-cms/blocks": "^0.18.0",
    "zod": "4.4.2"
  }
}
