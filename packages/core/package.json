{
  "name": "@dateline/core",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema-org": {
      "types": "./dist/schema-org.d.ts",
      "import": "./dist/schema-org.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js"
    },
    "./ical": {
      "types": "./dist/ical.d.ts",
      "import": "./dist/ical.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "peerDependencies": {
    "emdash": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dateline/blocks": "workspace:*",
    "@dateline/recurring": "workspace:*",
    "ical-generator": "10.2.0",
    "zod": "4.4.2"
  }
}
