{
  "name": "@dateline/core",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./sandbox": {
      "types": "./dist/plugin.d.mts",
      "import": "./dist/plugin.mjs",
      "default": "./dist/plugin.mjs"
    },
    "./schema-org": {
      "types": "./dist/schema-org.d.ts",
      "import": "./dist/schema-org.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js"
    },
    "./ical": {
      "types": "./dist/ical.d.ts",
      "import": "./dist/ical.js"
    }
  },
  "files": [
    "dist",
    "emdash-plugin.jsonc"
  ],
  "scripts": {
    "build": "mkdir -p node_modules/.cache/emdash-build && TMPDIR=./node_modules/.cache/emdash-build emdash-plugin build && node ../../tools/bundle-sandbox-plugin.mjs && tsc -b",
    "dev": "emdash-plugin dev",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "peerDependencies": {
    "emdash": "^0.18.0"
  },
  "devDependencies": {
    "@emdash-cms/plugin-cli": "^0.5.1",
    "@types/node": "^20.19.39",
    "esbuild": "^0.27.7",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dateline/blocks": "workspace:*",
    "@dateline/recurring": "workspace:*",
    "ical-generator": "10.2.0",
    "zod": "4.4.2"
  }
}
