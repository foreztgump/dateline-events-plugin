{
  "name": "@dateline/importer",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./sandbox": {
      "import": "./dist/plugin.mjs",
      "types": "./dist/plugin.d.mts",
      "default": "./dist/plugin.mjs"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js"
    }
  },
  "files": [
    "dist",
    "emdash-plugin.jsonc",
    "README.md"
  ],
  "scripts": {
    "build": "mkdir -p node_modules/.cache/emdash-build && TMPDIR=./node_modules/.cache/emdash-build emdash-plugin build && tsc -b",
    "dev": "emdash-plugin dev",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "peerDependencies": {
    "emdash": "^0.18.0"
  },
  "devDependencies": {
    "@emdash-cms/plugin-cli": "^0.5.1",
    "@types/node": "^20.19.39",
    "eslint": "^9.27.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dateline/blocks": "workspace:*",
    "@dateline/core": "workspace:*",
    "ical.js": "2.2.1",
    "zod": "4.4.2"
  }
}
