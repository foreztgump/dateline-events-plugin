{
  "name": "@dateline/recurring",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "description": "Helper library extending Dateline events with RFC 5545 recurrence: RRULE validation, lazy on-read materialization with a 2-year cap, KV range caching, and DST-aware IANA timezone handling.",
  "keywords": [
    "dateline",
    "recurrence",
    "rrule",
    "rfc5545",
    "ical",
    "timezone",
    "events"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foreztgump/dateline-events-plugin.git",
    "directory": "packages/recurring"
  },
  "homepage": "https://github.com/foreztgump/dateline-events-plugin/tree/main/packages/recurring#readme",
  "bugs": {
    "url": "https://github.com/foreztgump/dateline-events-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "peerDependencies": {
    "emdash": "^0.18"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "rrule": "2.8.1",
    "zod": "4.4.2"
  }
}
