---
import EventCard from "./EventCard.astro";
import { eventsOnDate } from "../lib/calendar.js";
import type { CalendarDayProps } from "./component-props.js";
const { events, date } = Astro.props as CalendarDayProps;
const dayEvents = eventsOnDate(events, date);
---
<section class="dt-calendar-day grid gap-4" aria-label={`Events on ${date}`} data-dateline-component="CalendarDay">
  <h2 class="text-xl font-semibold"><time datetime={date}>{date}</time></h2>
  {dayEvents.map((event) => <EventCard event={event} expanded />)}
</section>
