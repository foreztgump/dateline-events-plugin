---
import { formatEventDateTime } from "../lib/format.js";
import type { EventHeroProps } from "./component-props.js";
const { event } = Astro.props as EventHeroProps;
---
<header class="dt-event-hero rounded bg-slate-950 p-8 text-white" data-dateline-component="EventHero">
  {event.featuredImage && <img class="dt-event-hero__image mb-4 rounded" src={event.featuredImage} alt="" />}
  <p class="dt-event-hero__eyebrow">{formatEventDateTime(event)}</p>
  <h1 class="dt-event-hero__title text-4xl font-bold">{event.title}</h1>
  {event.shortDescription && <p class="dt-event-hero__summary mt-3">{event.shortDescription}</p>}
</header>
