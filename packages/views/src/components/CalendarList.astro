---
import EventCard from "./EventCard.astro";
import { groupEventsByDate } from "../lib/calendar.js";
import type { CalendarListProps } from "./component-props.js";

const { events } = Astro.props as CalendarListProps;
const groups = groupEventsByDate(events);
---
<section class="dt-calendar-list space-y-6" data-dateline-component="CalendarList">
  {groups.map((group) => <section class="dt-calendar-list__group"><h2 class="border-l-4 border-blue-600 pl-3 text-xl font-semibold"><time datetime={group.date}>{group.date}</time></h2><div class="mt-3 grid gap-3">{group.events.map((event) => <EventCard event={event} />)}</div></section>)}
</section>
