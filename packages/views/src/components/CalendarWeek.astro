---
import { buildWeekDays, eventsOnDate } from "../lib/calendar.js";
import { eventHref, formatEventTimeRange } from "../lib/format.js";
import type { CalendarWeekProps } from "./component-props.js";
const { events, weekStart } = Astro.props as CalendarWeekProps;
const days = buildWeekDays(weekStart);
---
<section class="dt-calendar-week grid grid-cols-1 gap-3 md:grid-cols-7" aria-label={`Events for week of ${weekStart}`} data-dateline-component="CalendarWeek">
  {days.map((date) => <article class="min-h-40 rounded border p-3" data-date={date}><h3 class="font-semibold"><time datetime={date}>{date}</time></h3>{eventsOnDate(events, date).map((event) => <a class="mt-2 block rounded bg-blue-100 p-2" href={eventHref(event)}>{event.title}<span class="block text-sm">{formatEventTimeRange(event)}</span></a>)}</article>)}
</section>
