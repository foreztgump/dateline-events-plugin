---
import type { VenueMapProps } from "./component-props.js";
import { safeHref } from "../lib/url.js";
const { venue } = Astro.props as VenueMapProps;
const coordinates = venue?.geo ? `${venue.geo.lat},${venue.geo.lng}` : undefined;
const websiteHref = safeHref(venue?.website);
---
<section class="dt-venue-map rounded border p-4" data-dateline-component="VenueMap">
  {venue ? <><h3 class="font-semibold">{venue.name}</h3>{coordinates && <p data-coordinates={coordinates}>Map coordinates: {coordinates}</p>}{websiteHref && <a class="underline" href={websiteHref}>Venue website</a>}</> : <p>Venue details unavailable.</p>}
</section>
