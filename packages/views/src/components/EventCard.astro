---
import { eventHref, formatEventDateTime, formatEventTimeRange } from "../lib/format.js";
import type { EventCardProps } from "./component-props.js";

const { event, expanded = false, venue, organizers = [] } = Astro.props as EventCardProps;
---
<article class="dt-event-card rounded border p-4 shadow-sm" data-dateline-component="EventCard" data-event-id={event.id}>
  <a class="dt-event-card__top block" href={eventHref(event)} aria-expanded={String(expanded)}>
    <time datetime={event.startsAt}>{formatEventDateTime(event)}</time>
    <h3 class="text-lg font-semibold">{event.title}</h3>
  </a>
  {expanded && (
    <div class="dt-event-card__detail mt-3 grid gap-2">
      <p>{event.shortDescription}</p>
      <p><strong>Time:</strong> {formatEventTimeRange(event)}</p>
      {venue && <p><strong>Location:</strong> {venue.name}</p>}
      {organizers.length > 0 && <p><strong>Organizer:</strong> {organizers.map((organizer) => organizer.name).join(", ")}</p>}
    </div>
  )}
</article>
