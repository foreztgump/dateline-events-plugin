---
import { agendaEvents } from "../lib/calendar.js";
import { formatEventTimeRange, eventHref } from "../lib/format.js";
import type { CalendarAgendaProps } from "./component-props.js";
const { events, limit } = Astro.props as CalendarAgendaProps;
const visibleEvents = agendaEvents(events, limit);
---
<ol class="dt-calendar-agenda divide-y rounded border" data-dateline-component="CalendarAgenda">
  {visibleEvents.map((event) => <li class="grid gap-1 p-3"><time datetime={event.startsAt}>{formatEventTimeRange(event)}</time><a class="font-semibold underline" href={eventHref(event)}>{event.title}</a></li>)}
</ol>
