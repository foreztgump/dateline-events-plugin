{
  "name": "@dateline/views",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "description": "Native Astro component library for Dateline themes: calendar (month/week/day/agenda/list), event cards, event details, venue maps, and organizer cards, wired to EmDash's content API.",
  "keywords": [
    "dateline",
    "astro",
    "emdash",
    "events",
    "calendar",
    "components",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foreztgump/dateline-events-plugin.git",
    "directory": "packages/views"
  },
  "homepage": "https://github.com/foreztgump/dateline-events-plugin/tree/main/packages/views#readme",
  "bugs": {
    "url": "https://github.com/foreztgump/dateline-events-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components/*": "./dist/components/*"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/copy-astro.mjs",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --cache",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.cache *.tsbuildinfo",
    "lint:fix": "eslint src --cache --fix"
  },
  "peerDependencies": {
    "astro": "^6.1.10",
    "emdash": "^0.18"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "rimraf": "^6.0.1",
    "astro": "^6.1.10"
  },
  "dependencies": {
    "@dateline/core": "workspace:*"
  }
}
