{
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(rm -rf $HOME)",
      "Bash(:(){ :|:& };:)",
      "Bash(dd if=* of=/dev/sd*)",
      "Bash(dd if=* of=/dev/hd*)",
      "Bash(dd if=* of=/dev/nvme*)",
      "Bash(mkfs.*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod 666 *)",
      "Bash(chmod -R 666 *)",
      "Bash(chmod o+w *)",
      "Bash(chmod a+w *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(sftp *)",
      "Bash(* > /dev/*)",
      "Bash(* >> /dev/*)",
      "Bash(chown -R * /)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(eval *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git push * develop)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push origin develop:*)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(npx wrangler delete *)",
      "Bash(npx wrangler kv:namespace delete *)",
      "Bash(npx wrangler r2 bucket delete *)",
      "Bash(stripe events resend *)",
      "Bash(sudo *)",
      "Bash(su -)",
      "Bash(passwd *)",
      "Bash(*--no-preserve-root*)",
      "Bash(* > /dev/sd*)",
      "Bash(* > /dev/hd*)",
      "Bash(* > /dev/nvme*)",
      "Bash(* > /dev/vd*)",
      "Bash(* > /dev/xvd*)",
      "Bash(* >> /dev/sd*)",
      "Bash(* >> /dev/nvme*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.ssh/**)",
      "Read(**/credentials)",
      "Read(**/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write(.env)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.production)",
      "Edit(.env)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.production)"
    ],
    "allow": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-bash-firewall.sh" },
          { "type": "command", "command": ".claude/hooks/pre-bash-protected-branch.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-edit-secrets.sh" },
          { "type": "command", "command": ".claude/hooks/pre-edit-worktree-boundary.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-edit-autoformat.sh" }
        ]
      }
    ]
  }
}
